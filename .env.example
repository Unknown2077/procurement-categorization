DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/db_name
NIM_API_KEY=replace_me
NIM_BASE_URL=https://example-llm-endpoint/v1
NIM_MODEL=qwen/qwen3-next-80b-a3b-instruct

# sink type: http | db | file
SINK_TYPE=file

# HTTP sink
SINK_HTTP_BASE_URL=https://example-api.test
ACCOUNT_UID=
DATASET_UID=
API_PATH_INSERT_DATA=/api/v1/accounts/{account_uid}/datasets/{dataset_uid}/data
SINK_HTTP_PATH={API_PATH_INSERT_DATA}
SINK_HTTP_AUTH_TOKEN=
SINK_HTTP_TIMEOUT_SECONDS=30

# DB sink
SINK_DB_URL=postgresql://user:pass@127.0.0.1:5432/target_db
SINK_DB_SCHEMA=public
SINK_DB_TABLE=categorized_records

# File sink
SINK_FILE_PATH=outputs/categorized_records.jsonl
SINK_FILE_FORMAT=jsonl

# Load behavior
LOAD_BATCH_SIZE=10
LOAD_MAX_RETRIES=3
LOAD_RETRY_DELAY_SECONDS=2
LOAD_DEAD_LETTER_PATH=outputs/dead_letter_records.jsonl
