# --- Database (query-first ETL / manual DB flows; not read by api_check) ---
DB_URL=postgresql://user:pass@127.0.0.1:5432/db_name
# Required for --mode raw_to_api and --mode categorize_to_api unless you pass --source-sql.
# Optional for interactive/manual paths when you type SQL at prompts instead.
# Demo placeholder: in-memory rows only (replace with your real SELECT).
SOURCE_QUERY=SELECT * FROM (VALUES (1, 'sample row one'), (2, 'sample row two')) AS demo(id, description)
# Optional: cap rows read from SOURCE_QUERY result (omit = no cap). CLI: --source-row-limit
SOURCE_ROW_LIMIT=
# Optional: cap rows in sample_rows / sample_records in printed JSON. CLI: --preview-row-limit
PREVIEW_ROW_LIMIT=

# --- Target (validated when flows call load_neutral_runtime_config_from_env; ignored by api_check) ---
TARGET_TYPE=json
TARGET_API_BASE_URL=https://example-api.test
TARGET_ACCOUNT_UID=
TARGET_DATASET_UID=
TARGET_ACCESS_TOKEN=
# Insert URL template; {account_uid} and {dataset_uid} are substituted from env (see config.resolve_env_template).
TARGET_API_PATH_INSERT_DATA=/api/v1/accounts/{account_uid}/datasets/{dataset_uid}/data
TARGET_API_TIMEOUT_SECONDS=30
TARGET_OUTPUT_PATH=outputs/categorized_records.jsonl

# --- Batching, categorization flags, load retries (neutral + ETL load config) ---
BATCH_PROCESS=10
DO_CATEGORIZE=
CATEGORIZE_COLUMNS=
CATEGORIZE_MAX_RETRIES=3
LOAD_MAX_RETRIES=3
LOAD_RETRY_DELAY_SECONDS=2
DEAD_LETTER_PATH=outputs/dead_letter_records.jsonl

# --- api_check GET paths (defaults shown; {account_uid} resolved from TARGET_ACCOUNT_UID or --account-uid) ---
TARGET_API_PATH_AUTH_ME=/api/v1/auth/me
TARGET_API_PATH_ACCOUNT=/api/v1/accounts/{account_uid}
TARGET_API_PATH_DATASETS=/api/v1/accounts/{account_uid}/datasets
API_CHECK_TIMEOUT_SECONDS=30
API_CHECK_OUTPUT_DIR=outputs/api

# --- LLM (must be non-empty whenever neutral env is loaded; api_check skips that loader) ---
LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct
LLM_API_KEY=replace_me
LLM_BASE_URL=https://example-llm-endpoint/v1
